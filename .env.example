# =============================================================================
# Handphone — unified environment (local + Vercel)
# Copy to .env at the repo root:  cp .env.example .env
# Add the same variables in the Vercel project dashboard for production.
# =============================================================================

# --- Server ---
Mongo_Url=mongodb+srv://username:password@cluster.mongodb.net/handphone
PORT=5001
NODE_ENV=development

# Public app URL (local unified server or your Vercel domain)
FRONTEND_URL=http://localhost:5001
STRIPE_REDIRECT_BASE_URL=http://localhost:5001

# Used by Next.js middleware / SSR to reach the API (auto-set on Vercel if omitted)
# API_INTERNAL_URL=http://localhost:5001

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# --- Frontend (NEXT_PUBLIC_* are exposed to the browser) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional — only if API is hosted on a different origin
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_API_URL=/product
