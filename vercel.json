{
  "version": 2,
  "installCommand": "npm install && npm install --prefix client",
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "server/**",
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    { "src": "/user/(.*)", "dest": "api/index.js" },
    { "src": "/product/(.*)", "dest": "api/index.js" },
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "client/package.json" }
  ]
}
